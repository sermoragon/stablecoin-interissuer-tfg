generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Issuer {
  ISSUER_A
  ISSUER_B
}

enum PaymentStatus {
  CREATED
  ISO_OUTBOUND_BUILT
  ISO_SENT
  ISO_INBOUND_RECEIVED
  ISO_ACK_ACCEPTED
  ISO_ACK_REJECTED
  FAILED
}

enum IsoDirection {
  OUTBOUND
  INBOUND
}

enum IdempotencyStatus {
  PROCESSING
  COMPLETED
  FAILED
}

model Payment {
  id             String        @id @default(cuid())
  correlationId  String        @unique
  instructionId  String        @unique
  endToEndId     String
  senderIssuer   Issuer
  receiverIssuer Issuer
  amount         Decimal       @db.Decimal(18, 6)
  currency       String

  debtorName     String
  creditorName   String
  debtorBic      String
  creditorBic    String
  remittanceInfo String?

  status         PaymentStatus
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  messages       IsoMessage[]
  events         PaymentEvent[]

  @@index([status, createdAt])
}

model IsoMessage {
  id               String       @id @default(cuid())
  paymentId        String?
  payment          Payment?     @relation(fields: [paymentId], references: [id])
  direction        IsoDirection
  messageType      String
  messageId        String?
  relatedMessageId String?
  correlationId    String?
  sender           String
  receiver         String
  rawXml           String       @db.Text
  parsedJson       Json?
  createdAt        DateTime     @default(now())

  @@index([paymentId, createdAt])
  @@index([messageType, createdAt])
}

model PaymentEvent {
  id         String   @id @default(cuid())
  paymentId  String
  payment    Payment  @relation(fields: [paymentId], references: [id])
  type       String
  payload    Json?
  createdAt  DateTime @default(now())

  @@index([paymentId, createdAt])
}

model IdempotencyRecord {
  id                  String            @id @default(cuid())
  scope               String
  idempotencyKey      String
  requestHash         String
  status              IdempotencyStatus @default(PROCESSING)

  responseStatusCode  Int?
  responseContentType String?
  responseBody        String?           @db.Text

  resourceType        String?
  resourceId          String?

  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  completedAt         DateTime?

  @@unique([scope, idempotencyKey])
  @@index([status, createdAt])
  @@index([resourceType, resourceId])
}

model ReplayNonce {
  id                 String   @id @default(cuid())
  issuer             Issuer
  nonce              String
  idempotencyKey     String
  requestHash        String
  signatureTimestamp DateTime
  createdAt          DateTime @default(now())

  @@unique([issuer, nonce])
  @@index([issuer, signatureTimestamp])
}